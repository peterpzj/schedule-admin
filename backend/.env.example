# 服务配置
PORT=3000
NODE_ENV=production

# JWT 密钥（务必改成强密码）
JWT_SECRET=please-change-this-to-a-strong-random-secret-key-2026

# 默认管理员账号（首次启动会写入数据库）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 数据库路径
DB_PATH=./data/schedule.db

# 上传文件目录
UPLOAD_DIR=./uploads

# CORS 允许的来源（多个用逗号分隔，留空表示允许所有）
CORS_ORIGIN=*

# 日志
LOG_LEVEL=combined
