# 服务配置
PORT=3000
NODE_ENV=production

# JWT 密钥（务必改成强密码）
# 生成方式：openssl rand -base64 48   (要求 >= 32 字符)
# 如果不设置或保留占位符，后端启动会直接退出
JWT_SECRET=please-change-this-to-a-strong-random-secret-key-2026

# 默认管理员账号（首次启动会写入数据库）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 数据库路径
DB_PATH=./data/schedule.db

# 上传文件目录
UPLOAD_DIR=./uploads

# CORS 允许的来源（多个用逗号分隔）
# 示例：https://admin.your-domain.com,https://api.your-domain.com
# 留空 = 同源/无 origin（小程序）才放行，浏览器跨域会被拒
ALLOWED_ORIGINS=

# 限流（防爆破）
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW=15m
CREATE_USER_RATE_LIMIT=10
CREATE_USER_RATE_WINDOW=1h
GLOBAL_RATE_LIMIT=600
GLOBAL_RATE_WINDOW=10m

# 日志
LOG_LEVEL=combined

# 持久化 KV 存储（#P0-2 修复）
# 用途：登录失败桶 + token 黑名单 + 限流桶
#   - memory: 进程内 Map（单实例 OK，重启清零 → 攻击者可借重启窗口绕过）
#   - sqlite: 落盘到独立 store.db（推荐生产；多实例共享；跨重启保留）
STORE_BACKEND=sqlite
STORE_SQLITE_PATH=./data/store.db