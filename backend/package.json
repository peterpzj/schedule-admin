{
  "name": "schedule-admin-backend",
  "version": "1.0.0",
  "description": "诊室排班管理 - 后端 API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "migrate": "node db/migrate.js",
    "migrate:status": "node db/migrate.js --status",
    "migrate:create": "node db/migrate.js --create",
    "test": "node --test \"test/**/*.test.js\" \"lib/**/*.test.js\" \"middleware/**/*.test.js\"",
    "test:watch": "node --test --watch \"test/**/*.test.js\" \"lib/**/*.test.js\" \"middleware/**/*.test.js\"",
    "test:unit": "node --test \"lib/**/*.test.js\" \"middleware/**/*.test.js\"",
    "test:integration": "node --test \"test/**/*.test.js\"",
    "test:coverage": "echo 'coverage TBD'",
    "audit:verify": "node scripts/audit-verify.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "supertest": "^7.0.0"
  }
}
