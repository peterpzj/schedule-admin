# 测试用环境变量（仅在 vitest 启动时通过 dotenv 加载）
#   - 不影响开发（admin/.env.example）和生产
#   - 所有"必填"强校验项都给个固定值，不 exit(78)
JWT_SECRET_CURRENT=test_jwt_secret_for_ci_only_at_least_32_chars
JWT_SECRET=test_jwt_secret_for_ci_only_at_least_32_chars
JWT_REFRESH_SECRET=test_jwt_refresh_secret_for_ci_only_at_least_32_chars
ADMIN_USERNAME=testadmin
ADMIN_PASSWORD=testpassword123
NODE_ENV=test
PORT=0
DB_PATH=./data/test.db
LOG_LEVEL=error
STORE_BACKEND=memory
GLOBAL_RATE_LIMIT=999999
LOGIN_RATE_LIMIT=999999
ACCOUNT_LOGIN_RATE_LIMIT=999999
CREATE_USER_RATE_LIMIT=999999
EXCEL_RATE_LIMIT=999999
SCHEDULE_WRITE_RATE_LIMIT=999999