# ====== 全局环境变量（部署到腾讯云时改） ======

# ---------- JWT 密钥轮换配置 ----------
# 当前用于签发 token 的密钥。首次部署必须设置（>=32 字符随机字符串）
JWT_SECRET_CURRENT=please-change-this-to-a-strong-random-secret-key-min-32-chars
# 上一代密钥（轮换过渡期使用，验签旧 token）。平时留空
JWT_SECRET_PREVIOUS=
# 新一代密钥（仅在轮换预热期临时设置，进程会 warn 提示）。平时留空
JWT_SECRET_NEW=
# Token 过期时间（默认 7d，可写 1h/30m/7d 等）
JWT_EXPIRES_IN=7d

# ---------- 管理员账号（首次启动会写入数据库） ----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ---------- Nginx 反向代理域名（替换为你的实际域名） ----------
BACKEND_URL=http://backend:3000
FRONTEND_URL=https://admin.your-domain.com
API_BASE_URL=https://api.your-domain.com

# ---------- CORS 白名单（逗号分隔，可写多个域名；留空 = 仅同源） ----------
ALLOWED_ORIGINS=https://admin.your-domain.com,https://api.your-domain.com

# ---------- 限流阈值（可选，覆盖默认值） ----------
# 登录：5/15min
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW=15m
# 创建账号：10/h
CREATE_USER_RATE_LIMIT=10
CREATE_USER_RATE_WINDOW=1h
# 写排班：30/min
SCHEDULE_WRITE_RATE_LIMIT=30
SCHEDULE_WRITE_RATE_WINDOW=1m
# Excel 导入：5/h
EXCEL_RATE_LIMIT=5
EXCEL_RATE_WINDOW=1h
# 全局读：600/10min
GLOBAL_RATE_LIMIT=600
GLOBAL_RATE_WINDOW=10m

# ---------- 监控告警（可选，留空 = 不发告警） ----------
ALERT_WEBHOOK_URL=
ALERT_ERROR_RATE_THRESHOLD=0.05
ALERT_P99_LATENCY_MS=2000
ALERT_DISK_USAGE_PCT=80

# ---------- 备份（可选，覆盖默认路径） ----------
BACKUP_DIR=./data/backups
BACKUP_KEEP_DAYS=14
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=12
# COS 上传（可选，留空 = 只本地保留）
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=

# ---------- 日志 ----------
# 日志级别：debug | info | warn | error（默认 info）
LOG_LEVEL=info
# 输出格式：true=人类可读（开发用） false=JSON（生产用）
LOG_PRETTY=false
# HTTP 慢请求阈值（ms），超过会单独打 warn 日志
HTTP_SLOW_THRESHOLD_MS=2000
